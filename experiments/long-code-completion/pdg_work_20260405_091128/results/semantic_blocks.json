  "source_text": "\n\n\tdef python2_test_func(data_dict, output_file):\n        print \"Start processing...\"   # Python2 print\n\n        total = 0L   # long 类型\n\n        # 遍历 dict（Python2 写法）\n        for key, value in data_dict.iteritems():\n            if value > 10:\n                print key, value\n                total += value\n            elif value > 5:\n                print \"medium:\", key\n                total += value\n            else:\n                print \"small:\", key\n\n        # xrange\n        for i in xrange(3):\n            print i\n\n        # has_key\n        if data_dict.has_key(\"error\"):\n            print \"found error\"\n\n        # try-except-finally\n        try:\n            f = open(output_file, 'w')\n            print >> f, \"Result:\", total   # Python2 重定向输出\n        except IOError, e:\n            print \"IO Error:\", e\n            raise RuntimeError, \"write failed\"   # Python2 raise\n        finally:\n            try:\n                f.close()\n            except:\n                pass\n\n        return total\n"
}